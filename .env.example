# Redis connection URL. Vercel auto-injects REDIS_URL when you create a
# "Redis - Official Redis for Vercel" database from the project dashboard
# (Storage → Create Database → Redis). For local dev with a real Redis,
# paste the URL here. If empty, the app falls back to in-memory storage.
REDIS_URL=

# Legacy MongoDB. Only used if REDIS_URL is NOT set. If empty too, the
# in-memory store is used (fine for local dev, NOT for production).
MONGODB_URI=
MONGODB_DB=wc26_quini

# Admin password is now hardcoded in api/_lib/auth.js. No env var needed.

# Optional: comma-separated list of allowed origins for CORS. Defaults to "*".
ALLOWED_ORIGIN=*
