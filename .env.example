# MongoDB Atlas connection string. If empty, an in-memory store is used (great for
# local dev, NOT for Vercel production because data would be lost between
# invocations).
MONGODB_URI=

# Database name to use inside MongoDB.
MONGODB_DB=wc26_quini

# Shared secret required to call admin endpoints (results, recalculate, etc).
# The frontend sends it as `x-admin-key` when the admin enters it in the UI.
ADMIN_KEY=changeme

# Optional: comma separated list of allowed origins for CORS. Defaults to "*".
ALLOWED_ORIGIN=*
